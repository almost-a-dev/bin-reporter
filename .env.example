# House number/name and postcode to pre-populate on the missed-bin form.
BIN_HOUSE_NUMBER=340
BIN_POSTCODE=S34 8hs

# Only needed if BIN_HOUSE_NUMBER/BIN_POSTCODE match more than one property.
# Run the list_addresses tool to find the right UPRN.
#BIN_UPRN=

# Passphrase used to approve new OAuth clients (e.g. Claude Desktop) on the /authorize consent
# page. Not sent as a request header anymore — OAuth-issued access tokens are used for that.
MCP_AUTH_TOKEN=change-me

# Externally reachable https URL of this server, used as the OAuth issuer/resource identifier.
PUBLIC_URL=https://abc.domain.com

# Port the HTTP server listens on.
PORT=3000
